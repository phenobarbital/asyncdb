include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include SECURITY.md
include INSTALL.md
include README.md
include Makefile
include pyproject.toml
include setup.py

# Ship only the sources needed to build the package.
# (Compiled .so/.pyd are produced at build time by build_ext, not shipped in the sdist.)
recursive-include asyncdb *.py *.pyx *.pxd *.pyi
include asyncdb/py.typed

# Rust extension sources (NOT the build cache under target/)
recursive-include asyncdb/conversions/rst_convert *.rs Cargo.toml Cargo.lock

# --- Never ship build artifacts, caches or compiled blobs in the sdist ---
prune asyncdb/conversions/rst_convert/target
global-exclude *.pyc *.pyo *.pyd *.so *.o *.obj
global-exclude *.cpp
global-exclude *.c
recursive-exclude * __pycache__

# Exclude tests, settings, env, examples, docs and bin folders
prune docs
prune settings
prune env
prune examples
prune bin
prune tests
